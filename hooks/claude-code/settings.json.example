{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/poneglyph/hooks/posttooluse.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.config/poneglyph/hooks/userpromptsubmit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
